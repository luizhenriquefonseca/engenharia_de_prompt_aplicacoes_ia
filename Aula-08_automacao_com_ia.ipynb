# Aula 08: Automação com IA

## Missão 01: Automação de Arquivos

```python
import os
import shutil

# Código de organização de arquivos

def organizar_arquivos(diretorio):
    # Cria subdiretórios
    for tipo in ['imagens', 'documentos', 'áudio']:
        if not os.path.exists(os.path.join(diretorio, tipo)):
            os.makedirs(os.path.join(diretorio, tipo))

    # Move os arquivos
    for arquivo in os.listdir(diretorio):
        if arquivo.endswith('.jpg') or arquivo.endswith('.png'):
            shutil.move(os.path.join(diretorio, arquivo), os.path.join(diretorio, 'imagens', arquivo))
        elif arquivo.endswith('.pdf'):
            shutil.move(os.path.join(diretorio, arquivo), os.path.join(diretorio, 'documentos', arquivo))
        elif arquivo.endswith('.mp3'):
            shutil.move(os.path.join(diretorio, arquivo), os.path.join(diretorio, 'áudio', arquivo))

# Exemplo de uso
organizar_arquivos('/caminho/para/diretorio')
```

## Medidor de Temperatura

```python
import random
import time

def medir_temperatura():
    # Simula medição de temperatura
    return random.uniform(20.0, 30.0)

while True:
    temperatura = medir_temperatura()
    print(f'Temperatura atual: {temperatura:.2f}°C')
    time.sleep(60)  # Espera 1 minuto
```

## Missão 03: Sistema de Notificações

```python
import smtplib
from email.mime.text import MIMEText

# Função para enviar email

def enviar_notificacao(temperatura):
    msg = MIMEText(f'Atenção! A temperatura está em {temperatura:.2f}°C.')
    msg['Subject'] = 'Alerta de Temperatura'
    msg['From'] = 'seu_email@example.com'
    msg['To'] = 'destinatario@example.com'

    with smtplib.SMTP('smtp.example.com', 587) as server:
        server.starttls()
        server.login('seu_email@example.com', 'sua_senha')
        server.send_message(msg)

# Monitoramento autônomo

while True:
    temperatura = medir_temperatura()
    if temperatura > 25:
        enviar_notificacao(temperatura)
    time.sleep(60)  # Espera 1 minuto
```
